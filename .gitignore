# Dependencies
node_modules/
.worktrees/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output

# Build output
dist/
.generated/

# Packed tarballs — `pnpm pack` (without --dry-run) emits
# `<pkg>-<version>.tgz` at repo root for inspection / local install.
# Not source; shouldn't be committed. The npm-publish workflow handles
# the real release tarball directly. (pnpm pack:check uses --dry-run
# so it doesn't create a file at all — see package.json scripts.)
*.tgz

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Local Claude Code settings (contain absolute paths)
.claude/settings.local.json

# Ralph Loop session state (local, transient)
.claude/ralph-loop.local.md
.claude/.ralph-loop.local.md

# Serena MCP per-user memory (project-specific cache)
.serena/

# husky internals (generated by `prepare` script on install)
.husky/_/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript cache
*.tsbuildinfo

# Plugin state (generated at runtime — runtime/ephemeral state dirs only;
# the source-tree `lib/state/` is shipped code, hence the !-rescue).
state/
!lib/state/

# Stryker mutation testing artifacts
.stryker-tmp/
reports/mutation/

