# Default to LF line endings on checkout for all text-detected files.
# Without this, Windows contributors get CRLF, which churns diffs and
# breaks bash/zsh scripts under WSL.
* text=auto eol=lf

# Source files — always LF, even if auto-detection guesses otherwise.
*.mjs       text eol=lf
*.cjs       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.fish      text eol=lf

# Lockfiles — LF, but mark as generated so GitHub collapses diffs and
# Linguist excludes them from language stats.
pnpm-lock.yaml      text eol=lf linguist-generated=true
package-lock.json   text eol=lf linguist-generated=true

# Tests + scripts are project code, but they shouldn't dominate the
# Linguist language breakdown on GitHub. Mark as linguist-detectable
# but lower-weighted so the front-page stat reflects runtime code.
tests/**            linguist-vendored=false linguist-detectable=true
scripts/**          linguist-vendored=false linguist-detectable=true

# Fixtures bundled into the repo for tests are not "real" source —
# exclude from Linguist entirely.
tests/fixtures/**   linguist-vendored=true

# Documentation pages are docs, not code — keep them out of the
# language pie chart.
docs/**             linguist-documentation=true

# Binary types — never try to diff these as text.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.tgz       binary
*.gz        binary

# `git archive` (used by GitHub's "Download ZIP" button) excludes
# these — keeps the source tarball lean for casual downloaders.
# Note: this does NOT affect the npm tarball (controlled by
# package.json `files`), only the git-archive output.
.github/        export-ignore
.husky/         export-ignore
tests/          export-ignore
.editorconfig   export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
.nvmrc          export-ignore
biome.json      export-ignore
vitest.config.* export-ignore
stryker.config.* export-ignore
tsconfig*.json  export-ignore
