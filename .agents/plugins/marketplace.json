{
  "name": "artagon-agent-cli-plugin",
  "interface": {
    "displayName": "Artagon Agent CLI Plugin Suite"
  },
  "metadata": {
    "description": "Multi-backend ACP plugin suite. Each plugin is named for its host and drives the OTHER two backends via stateless CLI runners.",
    "version": "1.0.1"
  },
  "plugins": [
    {
      "name": "gemini",
      "source": {
        "source": "local",
        "path": "./plugins/gemini"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "interface": {
        "displayName": "Gemini Cross-Driver (drives Codex + Claude)"
      }
    },
    {
      "name": "claude",
      "source": {
        "source": "local",
        "path": "./plugins/claude"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "interface": {
        "displayName": "Claude Cross-Driver (drives Codex + Gemini)"
      }
    },
    {
      "name": "codex",
      "source": {
        "source": "local",
        "path": "./plugins/codex"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "interface": {
        "displayName": "Codex Cross-Driver (drives Gemini + Claude)"
      }
    }
  ]
}
