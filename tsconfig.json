{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["lib/**/*.mjs", "plugins/gemini/scripts/**/*.mjs", "types/**/*.d.ts"],
  "exclude": ["node_modules", "**/.generated/**", "tests/**"]
}
